# ─── OS & Editor ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ─── Node / Frontend ──────────────────────────────────────────────────
node_modules/
.svelte-kit/
ui/build/
ui/dist/
dist/
.env
.env.*
!.env.example
package-lock.json
ui/test-results/
ui/playwright-report/

# ─── Go / Backend ─────────────────────────────────────────────────────
backend/*/vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
coverage.html

# Compiled service binaries
backend/app-management/app-management
backend/core/core
backend/core/powerlab
backend/gateway/gateway
backend/user-service/user-service
backend/message-bus/message-bus
backend/local-storage/local-storage
backend/sync-catalog/sync-catalog

# ─── Runtime data — never commit (machine-local state) ────────────────
backend/runtime/
backend/logs/
backend/data/
backend/conf/
backend/*/runtime/
backend/*/logs/
backend/*/data/
# When a service is started from its own directory it sometimes resolves
# storage paths relative to its own root, producing a nested
# backend/<svc>/backend/{data,runtime,logs} tree. Ignore that too.
backend/*/backend/

# Root-level runtime configs (written by start.sh in dev)
/app-management.conf
/gateway.ini
/casaos.conf
/user-service.conf
/message-bus.conf
/local-storage.conf

# Test scratch outputs
**/test_output.txt
**/test-results/

# ─── Build Artifacts ──────────────────────────────────────────────────
*.log
# Demo fixtures are intentionally committed despite the *.log rule —
# static seed data baked into the MCP demo image.
!backend/powerlab-mcp/demo/journal/*.log
tmp/
.cache/

# ─── AI Agent Artifacts — must NEVER reach the repo ───────────────────
.gemini/
.claude/
.claude/settings.local.json
.antigravity/
**/.antigravity
**/.antigravity/
.cursor/
.cursorrules
.aider*
.copilot/
ai-context/
artifacts/
*.agent.md
# Top-level agent docs by name — never publish these
CLAUDE.md
CLAUDE.MD
AGENTS.md

# ─── Project-specific ─────────────────────────────────────────────────
# Upstream CasaOS snapshot images — not used by PowerLab
backend/core/snapshot*.png
backend/core/snapshot*.jpg

# Per-machine dev runtime config — regenerated from embedded sample on first boot
backend/gateway/gateway.ini

# mkdocs build output
docs-site/

# Auto-generated godoc markdown — produced by scripts/gen-godoc.sh
# in CI before mkdocs build. Only committed file in docs/api/<mod>/
# is index.md. Everything else under docs/api/<mod>/ (top-level
# .md and any subpackage subdir like route/, model/, service/,
# cmd/, codegen/, pkg/) is regenerated on every CI build.
docs/api/*/*.md
docs/api/*/*/
!docs/api/*/index.md

# Local dev runtime log dirs that get accidentally committed
backend/*/local_data/log/
backend/powerlab-mcp/smoke
